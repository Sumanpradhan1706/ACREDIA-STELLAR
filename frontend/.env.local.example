# ACREDIA canonical frontend environment example
# Copy this file to `.env.local` and replace placeholder values before running locally.
# Do not rename variables unless the source code is updated at the same time.

# Supabase public client configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role key
# Server-side only. Never expose this value in NEXT_PUBLIC_* variables.
# Required by admin API routes such as `/api/admin/stats` and `/api/admin/update-authorization`.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional dedicated HMAC secret for privacy-safe verification audit log hashes.
# Falls back to SUPABASE_SERVICE_ROLE_KEY when omitted.
VERIFICATION_LOG_HASH_SECRET=your_random_audit_hash_secret

# Admin access control
# Comma-separated list of emails that may access admin API routes.
ADMIN_EMAIL_ALLOWLIST=admin@example.com

# Stellar/Soroban contract configuration
# Acredia currently uses one unified Soroban contract for credential issuance,
# registry lookups, authorization, and revocation.
NEXT_PUBLIC_CREDENTIAL_NFT_CONTRACT=CCGDFDLPELTOWG5H5OA4MBR5OZWDP4XJI3S3TQZVZ7XTVP77EKOFORYF
NEXT_PUBLIC_CREDENTIAL_REGISTRY_CONTRACT=CCGDFDLPELTOWG5H5OA4MBR5OZWDP4XJI3S3TQZVZ7XTVP77EKOFORYF

# Stellar testnet network configuration
NEXT_PUBLIC_CHAIN_ID=testnet
NEXT_PUBLIC_NETWORK_NAME=testnet
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Pinata/IPFS configuration
# Server-only JWT used by the frontend IPFS API routes.
PINATA_JWT=your_pinata_jwt_token
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# Production safety
# Never put service-role keys, Pinata JWTs, or Stellar secret keys in NEXT_PUBLIC_* variables.
# Never paste real secrets into browser code, screenshots, logs, or GitHub issues.

# Optional debug logging
# Set to true only while debugging locally.
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=false
